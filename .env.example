# ─────────────────────────────────────────────
# ANOMALY DETECTION API — ENVIRONMENT CONFIG
# Copy this file to .env and adjust as needed.
# Never commit .env to version control.
# ─────────────────────────────────────────────

# Application
APP_NAME=Time Series Anomaly Detection API
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO
# Log output format. Use 'text' for local development (human-readable) or 'json' for production
# log aggregation (one JSON object per line, includes timestamp, level, logger, message, request_id).
LOG_FORMAT=text

# Storage
# Path where trained models and metadata are persisted.
# In Docker, this is volume-mounted from ./storage on the host.
STORAGE_PATH=./storage

# Validation thresholds
# Reject training data with fewer than this many data points.
MIN_DATA_POINTS=30

# Reject series whose standard deviation is below this value (constant series).
STD_THRESHOLD=1e-10

# Training validation extension rules
# Reject when the trailing window has all identical values (possible frozen/disconnected sensor).
FLAT_LINE_WINDOW=10
FLAT_LINE_ENABLED=false

# Reject when max interval exceeds this factor times the median interval.
MAX_TEMPORAL_GAP_FACTOR=2.0
TEMPORAL_GAP_ENABLED=false

# Metrics
# Maximum number of latency samples kept per endpoint for percentile calculation.
# Oldest samples are evicted when this limit is reached (FIFO).
MAX_LATENCY_SAMPLES=1000
