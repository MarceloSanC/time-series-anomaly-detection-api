# ─────────────────────────────────────────────
# ANOMALY DETECTION API — ENVIRONMENT CONFIG
# Copy this file to .env and adjust as needed.
# Never commit .env to version control.
# ─────────────────────────────────────────────

# Application
APP_HOST=0.0.0.0
APP_PORT=8000
LOG_LEVEL=INFO

# Storage
# Path where trained models and metadata are persisted.
# In Docker, this is volume-mounted from ./storage on the host.
STORAGE_PATH=./storage

# Validation thresholds
# Reject training data with fewer than this many data points.
MIN_DATA_POINTS=30

# Reject series whose standard deviation is below this value (constant series).
STD_THRESHOLD=1e-10

# Metrics
# Maximum number of latency samples kept per endpoint for percentile calculation.
# Oldest samples are evicted when this limit is reached (FIFO).
MAX_LATENCY_SAMPLES=1000
